# =====================================================================
# System & Machine Configuration
# =====================================================================
# System User/Group ID overrides (defaults to 1000:1000 inside containers)
UID=1000
GID=1000

# Base configuration directory path on the host
CONFIG=/path/to/config/directory

# Base mount directory for repositories and vaults on the host
MOUNT=/path/to/mount/directory


# =====================================================================
# Domain & DNS / SSL Configuration
# =====================================================================
# Domain used for all subdomains and Traefik routing
DOMAIN=localhost

# Cloudflare API Token for DNS SSL challenge (requires zone read/dns write)
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token_here

# Email associated with your Let's Encrypt SSL certificates
ACME_EMAIL=your_email@example.com


# =====================================================================
# Path & Volume Mounts (Host & Container mappings)
# =====================================================================
# OpenClaw workspace paths
CLAW_WORKSPACE_OUTSIDE=${CONFIG}/openclaw/workspace
CLAW_WORKSPACE_INSIDE=/home/node/.openclaw/workspace

# Common data directory (Host path maps to /data in container)
DATA_OUTSIDE=${MOUNT}/data
DATA_INSIDE=/data

# Wiki configuration
WIKI_OUTSIDE=${MOUNT}/vault/llm-wiki
WIKI_INSIDE=${DATA_INSIDE}/wiki

# Production deployment repository (for agent checkout review)
PROD_OUTSIDE=${MOUNT}/git/bully
PROD_INSIDE=${DATA_INSIDE}/production

# Obsidian vault path
VAULT_OUTSIDE=${MOUNT}/vault/obsidian
VAULT_INSIDE=${DATA_INSIDE}/vault


# =====================================================================
# Hermes Agent Configuration
# =====================================================================
HERMES_CONFIG_DIR=${CONFIG}/HERMES
HERMES_WORKSPACE_DIR=${HERMES_CONFIG_DIR}/workspace
HERMES_API_KEY=your_hermes_api_key_here


# =====================================================================
# OpenClaw Core Service Variables
# =====================================================================
WIKI=${CONFIG}/openclaw/wiki
OPENCLAW_CONFIG_DIR=${CONFIG}/openclaw
OPENCLAW_WORKSPACE_DIR=${OPENCLAW_CONFIG_DIR}/workspace
OPENCLAW_AUTH_PROFILE_SECRET_DIR=${OPENCLAW_CONFIG_DIR}/.secrets
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
OPENCLAW_NO_RESPAWN=1
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=your_md5_hashed_password_here
OPENCLAW_DISCORD_TOKEN=
ROUTER_API_KEY=

# Optional customizations
# OPENCLAW_DISABLE_BONJOUR=
# OPENCLAW_EXTRA_MOUNTS=
# OPENCLAW_HOME_VOLUME=
# OPENCLAW_IMAGE_APT_PACKAGES=
# OPENCLAW_IMAGE_PIP_PACKAGES=
# OPENCLAW_EXTENSIONS=
# OPENCLAW_INSTALL_BROWSER=
# OPENCLAW_SANDBOX=
# DOCKER_GID=
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
# OPENCLAW_TZ=

# OpenTelemetry Settings
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
# OTEL_EXPORTER_OTLP_PROTOCOL=
# OTEL_SERVICE_NAME=
# OTEL_SEMCONV_STABILITY_OPT_IN=
# OPENCLAW_OTEL_PRELOADED=
# OPENCLAW_SKIP_ONBOARDING=


# =====================================================================
# 9router Configuration
# =====================================================================
ROUTER_JWT_SECRET=change-me-to-a-long-random-secret
ROUTER_INITIAL_PASSWORD=change-me
ROUTER_API_KEY_SECRET=endpoint-proxy-api-key-secret
ROUTER_MACHINE_ID_SALT=endpoint-proxy-salt

# =====================================================================
# Discord Integration Settings
# =====================================================================
USER_DISCORD_ID=your_discord_user_id
DISCORD_SERVER_ID=your_discord_server_id

# Channels
DISCORD_CHANNEL_AGENT_COMMS=
DISCORD_CHANNEL_GENERAL=
DISCORD_CHANNEL_NORTHSTAR=
DISCORD_CHANNEL_CODE=

# Bot Credentials & Tokens
DISCORD_USER_ID_NORTHSTAR=
DISCORD_BOT_NORTHSTAR_TOKEN=

DISCORD_USER_ID_CODER=
DISCORD_BOT_CODER_TOKEN=

DISCORD_USER_ID_ADMIN=
DISCORD_BOT_ADMIN_TOKEN=

DISCORD_BOT_HERMES=


# =====================================================================
#LLM API Keys & Provider Settings
# =====================================================================
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Specialized API Keys
GOOGLE_SEARCH_API_KEY=
GOOGLE_INDEXING_KEY=

# Claude Browser Session Auth (if using browser-based scrapers)
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_COOKIE=
CLAUDE_WEB_SESSION_KEY=

# Telegram Integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
